{
  "manifest_version": 2,
  "name": "UI Workflow Recorder Pro",
  "version": "1.19.0",
  "description": "Record UI workflows with clean step titles, configurable redaction, and advanced reporting tools.",
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "downloads",
    "idle"
  ],
  "optional_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "frame_spool.js",
      "background.js"
    ],
    "persistent": true
  },
  "browser_action": {
    "default_title": "UI Recorder Pro",
    "default_icon": "icons/icon.svg",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "firefox-ui-recorder-pro@mrtmc325",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": [
          "websiteContent"
        ]
      }
    }
  },
  "commands": {
    "toggle-recording": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Start/stop recording"
    },
    "toggle-burst-capture": {
      "suggested_key": {
        "default": "Ctrl+Alt+G",
        "mac": "Command+Alt+G"
      },
      "description": "Toggle high-speed GIF burst mode"
    }
  }
}
